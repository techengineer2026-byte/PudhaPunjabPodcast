{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      {
        "source": "**",
        "has": [
          {
            "type": "host",
            "value": "puadh-punjabi-podcast.web.app"
          }
        ],
        "destination": "https://puadhpunjabipodcast.com",
        "type": 301
      },
      {
        "source": "**",
        "has": [
          {
            "type": "host",
            "value": "puadh-punjabi-podcast.firebaseapp.com"
          }
        ],
        "destination": "https://puadhpunjabipodcast.com",
        "type": 301
      }
    ]
  }
}